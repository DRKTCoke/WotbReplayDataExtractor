<?xml version="1.0" encoding="UTF-8"?>
<!--
  本项目专用 Maven 配置 (个人项目, 与公司 azdops feed / 凭据完全隔离)。
  用法: mvn -s settings.xml ...   (或在 java/ 目录下 mvn -s settings.xml)
  - 镜像: 所有依赖走 Aliyun 公共仓库 (Maven Central 在本网络被拦)。
  - 本地仓库: 单独放在项目内 .m2repo, 不与 ~/.m2/repository (含公司构件) 混用。
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
              https://maven.apache.org/xsd/settings-1.0.0.xsd">

    <localRepository>C:/Users/yu.chen/Desktop/MyPersonalProject/wotbDataExtracter/java/.m2repo</localRepository>

    <mirrors>
        <mirror>
            <id>aliyun-public</id>
            <name>Aliyun Public Mirror (proxies Maven Central)</name>
            <url>https://maven.aliyun.com/repository/public</url>
            <mirrorOf>*</mirrorOf>
        </mirror>
    </mirrors>
</settings>
